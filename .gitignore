# Native compilation
*.eln

# Byte-compiled
*.elc

# straight.el — managed by straight, not committed
straight/

# ELPA packages
elpa/

# Backups and auto-saves
backups/
auto-save-list/
*~
\#*\#
.#*

# Cache directories (runtime state, not config)
cache/
data/

# Emacs server / daemon sockets
server/

