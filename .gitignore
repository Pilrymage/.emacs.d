recentf
ido.last
places
history
url/

# eshell history
eshell/history
eshell/lastdir

# Rime user data (synced separately)
rime/sync/

# Custom file (managed by M-x customize — commit if you want tracked settings)
# custom.el

# OS artifacts
.DS_Store
Thumbs.db

# Emacs network security
network-security.data

# Org-mode id locations (auto-generated)
.org-id-locations

